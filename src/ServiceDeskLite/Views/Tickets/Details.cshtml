@model ServiceDeskLite.Models.Ticket

@{
    ViewData["Title"] = "Ticket Details";
    string BadgeClass(string status) => status switch
    {
        "Open" => "badge-open",
        "InProgress" => "badge-inprogress",
        "Closed" => "badge-closed",
        _ => "bg-secondary"
    };
}

<div class="page-header">
    <div>
        <h2 class="page-title">@Model.Title</h2>
        <p class="page-subtitle">
            Ticket <span class="mono">#@Model.Id</span>
            · <span class="badge @BadgeClass(Model.Status)">@Model.Status</span>
            · Created @Model.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card card-elev">
            <div class="card-body">
                <h5 class="mb-2">Description</h5>
                <div class="text-muted" style="white-space: pre-wrap;">@Model.Description</div>

                <hr class="my-4" />

                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <div class="text-muted small">Assigned To</div>
                        <div class="fw-semibold">@Model.User?.Name</div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <form asp-action="SetStatus" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="Open" />
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Set Open</button>
                        </form>

                        <form asp-action="SetStatus" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="InProgress" />
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Set In Progress</button>
                        </form>

                        <form asp-action="SetStatus" asp-route-id="@Model.Id" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="status" value="Closed" />
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Close</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="card card-elev mt-3">
            <div class="card-body">
                <h5 class="mb-3">Comments</h5>

                @if (Model.Comments == null || !Model.Comments.Any())
                {
                    <div class="text-muted">No comments yet. Add the first update below.</div>
                }
                else
                {
                    <div class="d-flex flex-column gap-3">
                        @foreach (var c in Model.Comments.OrderByDescending(x => x.CreatedAtUtc))
                        {
                            <div>
                                <div class="small text-muted">
                                    @c.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                                </div>
                                <div style="white-space: pre-wrap;">@c.Content</div>
                            </div>
                        }
                    </div>
                }

                <hr class="my-4" />

                <form asp-action="AddComment" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label">Add Comment</label>
                        <textarea name="content" class="form-control" rows="3" placeholder="Add an update, root cause, or resolution..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-brand">Post Comment</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-elev">
            <div class="card-body">
                <h5 class="mb-3">Summary</h5>

                <div class="mb-2">
                    <div class="text-muted small">Status</div>
                    <div class="fw-semibold">
                        <span class="badge @BadgeClass(Model.Status)">@Model.Status</span>
                    </div>
                </div>

                <div class="mb-2">
                    <div class="text-muted small">Assigned To</div>
                    <div class="fw-semibold">@Model.User?.Name</div>
                </div>

                <div class="mb-2">
                    <div class="text-muted small">Created</div>
                    <div class="fw-semibold">@Model.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</div>
                </div>

                <div class="text-muted small mt-3">
                    This MVP demonstrates MVC + EF Core + SQL Server with basic workflow and support-style updates.
                </div>
            </div>
        </div>
    </div>
</div>