@model IEnumerable<ServiceDeskLite.Models.Ticket>

@{
    ViewData["Title"] = "Tickets";
    string BadgeClass(string status) => status switch
    {
        "Open" => "badge-open",
        "InProgress" => "badge-inprogress",
        "Closed" => "badge-closed",
        _ => "bg-secondary"
    };
}

<div class="page-header">
    <div>
        <h2 class="page-title">Tickets</h2>
        <p class="page-subtitle">Create, assign, and track internal support tickets.</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-brand">
            + New Ticket
        </a>
    </div>
</div>

<div class="card card-elev">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 44%;">Title</th>
                        <th style="width: 16%;">Status</th>
                        <th style="width: 20%;">Assigned To</th>
                        <th style="width: 20%;">Created</th>
                        <th style="width: 1%;"></th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="p-4 text-muted">
                            No tickets yet. Create your first ticket to get started.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var t in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@t.Title</div>
                                <div class="text-muted small">#<span class="mono">@t.Id</span></div>
                            </td>
                            <td>
                                <span class="badge @BadgeClass(t.Status)">@t.Status</span>
                            </td>
                            <td>@(t.User?.Name ?? "Unassigned")</td>
                            <td class="text-muted">@t.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">View</a>
                                <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>