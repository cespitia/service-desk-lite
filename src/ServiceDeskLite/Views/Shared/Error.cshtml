@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Something went wrong</h2>
        <p class="page-subtitle">An unexpected error occurred while processing your request.</p>
    </div>
    <div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-brand">Back to Dashboard</a>
    </div>
</div>

<div class="card card-elev">
    <div class="card-body">
        <p class="mb-2">
            If this issue persists, try again or return to the dashboard.
        </p>

        @if (Model?.ShowRequestId ?? false)
        {
            <div class="text-muted small">
                Request ID: <span class="mono">@Model.RequestId</span>
            </div>
        }
    </div>
</div>